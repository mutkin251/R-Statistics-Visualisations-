CREATE TABLE developers AS
SELECT
app_id,
UNNEST(json_extract_string(developers_json, '$[*]')) AS developer
FROM games_raw
WHERE developers_json IS NOT NULL
AND developers_json != 'null'
AND developers_json != 'NA'
")
