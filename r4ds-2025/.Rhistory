# ---------- Helper: pdf and cdf of Exp(lambda) ----------
dexp_r <- function(x, lambda) {
ifelse(x >= 0, lambda * exp(-lambda * x), 0)
}
pexp_r <- function(x, lambda) {
ifelse(x >= 0, 1 - exp(-lambda * x), 0)
}
# ---------------- Part (a) ----------------
# P(X >= x) for X ~ Exp(lambda)
lambda <- 1.2
x0 <- 2.0
p_ge_x_formula <- exp(-lambda * x0)
p_ge_x_formula  # result
# numeric check: integral from x0 to Inf of lambda*exp(-lambda t) dt
p_ge_x_numeric <- integrate(function(t) lambda * exp(-lambda * t), lower = x0, upper = Inf)$value
p_ge_x_numeric
mean_X <- 1 / lambda
var_X  <- 1 / (lambda^2)
sd_X   <- sqrt(var_X)
mean_X
sd_X
mean_numeric <- integrate(function(t) t * lambda * exp(-lambda * t), lower = 0, upper = Inf)$value
mean_numeric
# second moment
second_moment <- integrate(function(t) t^2 * lambda * exp(-lambda * t), lower = 0, upper = Inf)$value
var_numeric <- second_moment - mean_numeric^2
sqrt(var_numeric)
library(tidyverse)
library(ggplot2)
##########################################---   1
# pdf and cdf of Exp
dexp_r <- function(x, lambda) {
ifelse(x >= 0, lambda * exp(-lambda * x), 0)
}
pexp_r <- function(x, lambda) {
ifelse(x >= 0, 1 - exp(-lambda * x), 0)
}
########   a
# P(X >= x) for X ~ Exp(lambda)
lambda <- 1.2
x0 <- 2.0
# base work
p_ge_x_formula <- exp(-lambda * x0)
p_ge_x_formula
# check in other way:
p_ge_x_numeric <- integrate(function(t) lambda * exp(-lambda * t), lower = x0, upper = Inf)$value
p_ge_x_numeric
#######   b
# Mean and standard deviation
mean_X <- 1 / lambda
var_X  <- 1 / (lambda^2)
sd_X   <- sqrt(var_X)
mean_X
sd_X
mean_numeric <- integrate(function(t) t * lambda * exp(-lambda * t), lower = 0, upper = Inf)$value
mean_numeric # check by integration
######    c
# T = min(X1, X2)
# P(T >= t) = e^{-2 lambda t}
# So T +-= Exp(2*lambda)
lambda <- 1.5
lambda_T <- 2 * lambda
# CDF and PDF of T
F_T <- function(t) { ifelse(t >= 0, 1 - exp(-lambda_T * t), 0) }
f_T <- function(t) { ifelse(t >= 0, lambda_T * exp(-lambda_T * t), 0) }
tvals <- seq(0, 3, by = 0.5)
data.frame(t = tvals,
P_T_ge_t = exp(-lambda_T * tvals),
CDF_T = sapply(tvals, F_T),
PDF_T = sapply(tvals, f_T))
# mean(T) should be 1/(2*lambda)
mean_T_analytical <- 1 / lambda_T
mean_T_analytical
# simulate
set.seed(52)
n <- 5e5
X1 <- rexp(n, rate = lambda)
X2 <- rexp(n, rate = lambda)
T_sim <- pmin(X1, X2)
mean(T_sim)
sd(T_sim)
#####   d
lambda1 <- 2
lambda2 <- 3
lambda3 <- 5
# until first failure
lambda_total <- lambda1 + lambda2 + lambda3
expected_time_first_failure <- 1 / lambda_total
lambda_total
expected_time_first_failure  # in years
# checking
set.seed(52)
n <- 2e5
B1 <- rexp(n, rate = lambda1)
B2 <- rexp(n, rate = lambda2)
B3 <- rexp(n, rate = lambda3)
Tmin_sim <- pmin(B1, B2, B3)
mean(Tmin_sim)
sd(Tmin_sim)
emp_cdf <- ecdf(Tmin_sim)
tt <- seq(0, 1, length.out = 100)
plot(tt, emp_cdf(tt), type = "l", col = "blue", lwd = 2,
main = "Empirical CDF of Tmin vs Theoretical CDF",
xlab = "t (years)", ylab = "CDF")
lines(tt, 1 - exp(-lambda_total * tt), col = "red", lwd = 2, lty = 2)
legend("bottomright", legend = c("empirical", "theoretical (Exp(lambda_total))"),
col = c("blue", "red"), lwd = 2, lty = c(1,2))
n <- 400
p_volodymyr <- 0.50
p_petro <- 0.20
p_rest <- 1 - (p_volodymyr + p_petro)
clt_prob <- function(p_true, n, p_cutoff, direction = "greater") {
mean_p <- p_true
sd_p <- sqrt(p_true * (1 - p_true) / n)
z <- (p_cutoff - mean_p) / sd_p
if (direction == "greater") {
return(1 - pnorm(z))
} else if (direction == "less") {
return(pnorm(z))
} else {
stop("direction must be 'greater' or 'less'")
}
} # func for CLT
#####   a
p_cutoff_vol <- 0.525
prob_vol_over_52_5 <- clt_prob(p_volodymyr, n, p_cutoff_vol, "greater")
prob_vol_over_52_5
p_cutoff_rest <- 0.31
prob_rest_less_31 <- clt_prob(p_rest, n, p_cutoff_rest, "less")
prob_rest_less_31
cat("\n--- Results (Elections problem) ---\n")
cat(sprintf("a) P(Volodymyr >= 52.5%%) ≈ %.4f\n", prob_vol_over_52_5))
cat(sprintf("b) P(Yulia/Viktor/Leonid < 31%%) ≈ %.4f\n", prob_rest_less_31))
n <- 1000
a <- -5 # min kopiykas
b <- 5  # max kopiykas
mu_x <- (a + b) / 2         # should be 0
var_x <- (b - a)^2 / 12     # = 100/12
sd_x <- sqrt(var_x)
mu_S <- n * mu_x
var_S <- n * var_x
sd_S <- sqrt(var_S)
threshold <- 100
# CLT approximation: S_n approximately N(mu_S, var_S)
z_pos <- (threshold - mu_S) / sd_S
p_exceed <- 2 * (1 - pnorm(z_pos))
cat("--- CLT approximation (units: kopiykas) ---\n")
cat(sprintf("Single-order mean = %.4f, sd = %.6f\n", mu_x, sd_x))
cat(sprintf("Sum mean = %.4f, sum sd = %.6f\n", mu_S, sd_S))
cat(sprintf("z = %.6f\n", z_pos))
cat(sprintf("Estimated p = P(|S_n| > %d) ≈ %.6f\n\n", threshold, p_exceed))
# x grid for X and Y
x_lim <- c(0, 10)
x <- seq(x_lim[1], x_lim[2], length.out = 1000)
# density f_X and f_Y
fX <- exp(-x)     # f_X(x)
y <- seq(0, 30, length.out = 1000)
fY <- (1/3) * exp(-y/3) # f_Y(y)
# density for V = X^3
v <- seq(0, 2000, length.out = 1000)
fV <- (1/3) * v^(-2/3) * exp(-v^(1/3))
fV[1] <- (1/3) * (0 + 0)  # formula has limit -> +Inf so almoust 0
# make data frames for ggplot
dfX <- tibble(t = x, density = fX, var = "X ~ Exp(1)")
dfY <- tibble(t = y, density = fY, var = "Y = 3X")
dfV <- tibble(t = v, density = fV, var = "V = X^3")
p1 <- ggplot(dfX, aes(t, density)) + geom_line() +
labs(title = "f_X(x) = e^{-x}", x = "x", y = "density") + theme_minimal()
p2 <- ggplot(dfY, aes(t, density)) + geom_line() +
labs(title = "f_Y(y) = (1/3) e^{-y/3}", x = "y", y = "density") + theme_minimal()
p3 <- ggplot(dfV, aes(t, density)) + geom_line() +
labs(title = "f_V(v) = (1/3) v^{-2/3} e^{-v^{1/3}}", x = "v", y = "density") + theme_minimal()
# arrange plots
grid.arrange(p1, p2, p3, nrow = 3)
