p_rest <- 1 - (p_volodymyr + p_petro)
clt_prob <- function(p_true, n, p_cutoff, direction = "greater") {
mean_p <- p_true
sd_p <- sqrt(p_true * (1 - p_true) / n)
z <- (p_cutoff - mean_p) / sd_p
if (direction == "greater") {
return(1 - pnorm(z))
} else if (direction == "less") {
return(pnorm(z))
} else {
stop("direction must be 'greater' or 'less'")
}
} # func for CLT
#####   a
p_cutoff_vol <- 0.525
prob_vol_over_52_5 <- clt_prob(p_volodymyr, n, p_cutoff_vol, "greater")
prob_vol_over_52_5
library(tidyverse)
library(ggplot2)
dexp_r <- function(x, lambda) {
ifelse(x >= 0, lambda * exp(-lambda * x), 0)
}
pexp_r <- function(x, lambda) {
ifelse(x >= 0, 1 - exp(-lambda * x), 0)
}
########   a
# P(X >= x) for X ~ Exp(lambda)
lambda <- 1.2
x0 <- 2.0
# base work
p_ge_x_formula <- exp(-lambda * x0)
p_ge_x_formula
# check in other way:
p_ge_x_numeric <- integrate(function(t) lambda * exp(-lambda * t), lower = x0, upper = Inf)$value
p_ge_x_numeric
#######   b
# Mean and standard deviation
mean_X <- 1 / lambda
var_X  <- 1 / (lambda^2)
sd_X   <- sqrt(var_X)
mean_X
sd_X
mean_numeric <- integrate(function(t) t * lambda * exp(-lambda * t), lower = 0, upper = Inf)$value
mean_numeric # check by integration
######    c
# T = min(X1, X2)
# P(T >= t) = e^{-2 lambda t}
# So T +-= Exp(2*lambda)
lambda <- 1.5
lambda_T <- 2 * lambda
# CDF and PDF of T
F_T <- function(t) { ifelse(t >= 0, 1 - exp(-lambda_T * t), 0) }
f_T <- function(t) { ifelse(t >= 0, lambda_T * exp(-lambda_T * t), 0) }
tvals <- seq(0, 3, by = 0.5)
data.frame(t = tvals,
P_T_ge_t = exp(-lambda_T * tvals),
CDF_T = sapply(tvals, F_T),
PDF_T = sapply(tvals, f_T))
# mean(T) should be 1/(2*lambda)
mean_T_analytical <- 1 / lambda_T
mean_T_analytical
# simulate
set.seed(52)
n <- 5e5
X1 <- rexp(n, rate = lambda)
X2 <- rexp(n, rate = lambda)
T_sim <- pmin(X1, X2)
mean(T_sim)
sd(T_sim)
#####   d
lambda1 <- 2
lambda2 <- 3
lambda3 <- 5
# until first failure
lambda_total <- lambda1 + lambda2 + lambda3
expected_time_first_failure <- 1 / lambda_total
lambda_total
expected_time_first_failure  # in years
# checking
set.seed(52)
n <- 2e5
B1 <- rexp(n, rate = lambda1)
B2 <- rexp(n, rate = lambda2)
B3 <- rexp(n, rate = lambda3)
Tmin_sim <- pmin(B1, B2, B3)
mean(Tmin_sim)
sd(Tmin_sim)
emp_cdf <- ecdf(Tmin_sim)
tt <- seq(0, 1, length.out = 100)
plot(tt, emp_cdf(tt), type = "l", col = "blue", lwd = 2,
main = "Empirical CDF of Tmin vs Theoretical CDF",
xlab = "t (years)", ylab = "CDF")
lines(tt, 1 - exp(-lambda_total * tt), col = "red", lwd = 2, lty = 2)
legend("bottomright", legend = c("calculated", "theoretical (Exp(lambda_total))"),
col = c("blue", "red"), lwd = 2, lty = c(1,2))
