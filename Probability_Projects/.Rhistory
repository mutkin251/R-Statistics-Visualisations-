n <- 1000
a <- -5 # min kopiykas
b <- 5  # max kopiykas
mu_x <- (a + b) / 2         # should be 0
var_x <- (b - a)^2 / 12     # = 100/12
sd_x <- sqrt(var_x)
mu_S <- n * mu_x
var_S <- n * var_x
sd_S <- sqrt(var_S)
threshold <- 100
# CLT approximation: S_n approximately N(mu_S, var_S)
z_pos <- (threshold - mu_S) / sd_S
p_exceed <- 2 * (1 - pnorm(z_pos))
cat("CLT approximation (units: kopiykas)")
cat(sprintf("Single-order mean = %.4f, sd = %.4f", mu_x, sd_x))
cat(sprintf("Sum mean = %.4f, sum sd = %.6f", mu_S, sd_S))
cat(sprintf("z = %.4f", z_pos))
cat(sprintf("Estimated p = P(|S_n| > %d) ≈ %.4f", threshold, p_exceed))
n <- 1000
a <- -5 # min kopiykas
b <- 5  # max kopiykas
mu_x <- (a + b) / 2         # should be 0
mu_x
