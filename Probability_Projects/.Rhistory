cat("E[Y] =", EY,"\n")
cat("Var[X] =", VarX,"\n")
cat("Var[Y] =", VarY,"\n")
cat("Cov[XY] =", CovXY,"\n")
cat("Corr[XY] =", CorrXY,"\n")
