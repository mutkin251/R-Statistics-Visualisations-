# for shitty nested values
safe_extract <- function(obj, ...) {
path <- list(...)
result <- obj
for (key in path) {
if (is.null(result) || !is.list(result)) return(NA)
result <- result[[key]]
}
if (is.null(result)) return(NA)
return(result)
} #this function was mostly made by chatGPT
